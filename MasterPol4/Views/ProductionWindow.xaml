<Page x:Class="MasterPol4.Views.ProductionWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Производство"
      Background="#FFFFFF">

    <Page.Resources>
        <Style TargetType="TextBox" x:Key="SearchBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="250"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="AlternatingRowBackground" Value="#F9F9F9"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="RowHeight" Value="45"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F4E8D3"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="Button" x:Key="AddButton">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="180"/>
            <Setter Property="Background" Value="#67BA80"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style TargetType="Button" x:Key="SaveButton">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Background" Value="#67BA80"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="10"/>
        </Style>

        <Style TargetType="Button" x:Key="CancelButton">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="10"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="StatusWaiting">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="StatusInProgress">
            <Setter Property="Background" Value="#F5A623"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="StatusCompleted">
            <Setter Property="Background" Value="#67BA80"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Управление производством" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>

        <Border Grid.Row="1" Background="#F9F9F9" Padding="15" CornerRadius="8" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="txtSearch" Style="{StaticResource SearchBox}" ToolTip="Поиск..." TextChanged="TxtSearch_TextChanged"/>
                <Button Content="Поиск" Width="80" Height="35" Margin="10,0,0,0" Background="#67BA80" Foreground="White" BorderThickness="0" Click="BtnSearch_Click" Cursor="Hand"/>
                <Button Content="Сбросить" Width="80" Height="35" Margin="10,0,0,0" Background="#E0E0E0" Foreground="#333333" BorderThickness="0" Click="BtnReset_Click" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <Button x:Name="btnAdd" Grid.Row="2" Content="+ Создать заказ" Style="{StaticResource AddButton}" HorizontalAlignment="Left" Click="BtnAdd_Click" Visibility="Collapsed"/>

        <DataGrid x:Name="dgOrders" Grid.Row="3">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№ заказа" Binding="{Binding OrderID}" Width="80"/>
                <DataGridTextColumn Header="Продукт" Binding="{Binding ProductName}" Width="250"/>
                <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="100"/>
                <DataGridTextColumn Header="Дата заказа" Binding="{Binding OrderDate, StringFormat=dd.MM.yyyy}" Width="120"/>
                <DataGridTextColumn Header="Дата завершения" Binding="{Binding CompletionDate, StringFormat=dd.MM.yyyy}" Width="120"/>
                <DataGridTemplateColumn Header="Статус" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Status}" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Ожидание">
                                                <Setter Property="Background" Value="#E74C3C"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="Padding" Value="8,3"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="В работе">
                                                <Setter Property="Background" Value="#F5A623"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="Padding" Value="8,3"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Завершено">
                                                <Setter Property="Background" Value="#67BA80"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="Padding" Value="8,3"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Действия" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Изменить статус" Style="{StaticResource ActionButton}" Background="#4A90D9" Foreground="White" Click="BtnChangeStatus_Click" Tag="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border x:Name="EditPanel" Grid.RowSpan="4" Background="#FFFFFF" BorderBrush="#CCCCCC" BorderThickness="2" CornerRadius="10" 
                Visibility="Collapsed" Width="450" Height="350" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Margin="25">
                <TextBlock Text="Создание заказа" FontSize="22" FontWeight="Bold" Margin="0,0,0,25" HorizontalAlignment="Center"/>

                <TextBlock Text="Продукт" FontWeight="SemiBold" Margin="0,5,0,5"/>
                <ComboBox x:Name="cmbProduct" Height="35" Margin="0,0,0,15" DisplayMemberPath="ProductName" SelectedValuePath="ProductID"/>

                <TextBlock Text="Количество" FontWeight="SemiBold" Margin="0,5,0,5"/>
                <TextBox x:Name="txtQuantity" Height="35" Margin="0,0,0,15"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,10">
                    <Button Content="Создать" Style="{StaticResource SaveButton}" Click="BtnSave_Click"/>
                    <Button Content="Отмена" Style="{StaticResource CancelButton}" Click="BtnCancel_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>