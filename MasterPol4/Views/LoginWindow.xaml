<Window x:Class="MasterPol4.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Мастер Пол - Вход"
        Height="500" 
        Width="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="/Resources/Мастер пол.ico">

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F4E8D3" Height="160">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Source="/Resources/Мастер пол.png" Width="80" Height="80" Stretch="Uniform" Margin="0,0,0,10"/>
                <TextBlock Text="МАСТЕР ПОЛ" FontSize="28" FontWeight="Bold" Foreground="#333333"/>
                <TextBlock Text="Вход в систему" FontSize="14" Foreground="#666666" Width="97" RenderTransformOrigin="0.487,0.616"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="320">
            <TextBlock Text="Логин" FontSize="13" FontWeight="SemiBold"/>
            <TextBox x:Name="txtUsername" Height="40" Margin="0,5,0,15"/>

            <TextBlock Text="Пароль" FontSize="13" FontWeight="SemiBold"/>
            <PasswordBox x:Name="txtPassword" Height="40" Margin="0,5,0,15"/>

            <Button x:Name="btnLogin" Content="ВОЙТИ" Height="45" Background="#67BA80" 
                    Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0"
                    Click="BtnLogin_Click" Cursor="Hand"/>

            <TextBlock x:Name="lblError" Foreground="Red" TextAlignment="Center" Margin="0,10,0,0" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Window>