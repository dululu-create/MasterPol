<Window x:Class="MasterPol4.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Мастер Пол - Система управления"
        Height="700" 
        Width="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="600"
        MinWidth="900"
        Icon="/Resources/Мастер пол.ico">

    <Window.Resources>
        <Style TargetType="Button" x:Key="NavButton">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8E8E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="ActiveNavButton" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="#F4E8D3"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F4E8D3" Height="100">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="20,0">
                    <Image Source="/Resources/Мастер пол.png" Height="51" Stretch="Uniform" Margin="0,0,15,0"/>
                    <StackPanel Height="58">
                        <TextBlock Text="МАСТЕР ПОЛ" FontSize="20" FontWeight="Bold" Foreground="#333333" Height="35"/>
                        <TextBlock Text="Система управления" FontSize="11" Foreground="#666666" Height="19" RenderTransformOrigin="0.506,-0.145"/>
                    </StackPanel>
                </StackPanel>

                <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button x:Name="btnPartners" Content="Партнеры" Style="{StaticResource NavButton}" Click="BtnPartners_Click"/>
                        <Button x:Name="btnProducts" Content="Продукция" Style="{StaticResource NavButton}" Click="BtnProducts_Click"/>
                        <Button x:Name="btnMaterials" Content="Материалы" Style="{StaticResource NavButton}" Click="BtnMaterials_Click"/>
                        <Button x:Name="btnWarehouse" Content="Склад" Style="{StaticResource NavButton}" Click="BtnWarehouse_Click"/>
                        <Button x:Name="btnProduction" Content="Производство" Style="{StaticResource NavButton}" Click="BtnProduction_Click"/>
                        <Button x:Name="btnEmployees" Content="Сотрудники" Style="{StaticResource NavButton}" Click="BtnEmployees_Click"/>
                        <Button x:Name="btnSales" Content="Продажи" Style="{StaticResource NavButton}" Click="BtnSales_Click"/>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock x:Name="lblUser" FontSize="13" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Button x:Name="btnLogout" Content="Выйти" Width="80" Height="30" 
                            Background="#67BA80" Foreground="#333333" 
                            BorderThickness="0" Click="BtnLogout_Click" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>